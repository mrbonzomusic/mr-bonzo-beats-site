---
import "../styles/global.css";
import { beatstarsLinks, socialLinks } from "../config/links";

interface Props {
  title?: string;
}

const { title = "Mr. Bonzo | Official" } = Astro.props;
const logoPath = "/images/logo-main.webp";

const discordInvite = socialLinks.discord || "https://discord.gg/hmpCHd4J"; 
const spotifyLink = socialLinks.spotify || "#";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-QFJSZGBGZE"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-QFJSZGBGZE');
    </script>
    <script data-goatcounter="https://mrbonzo.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>

    <style is:global>
      header#main-header {
        position: fixed !important;
        top: 0; left: 0; right: 0;
        z-index: 9999999 !important;
        padding-top: 0.75rem;
      }
      body {
        padding-top: 90px !important;
        background-color: black;
      }
      
      /* Mobile Menu Logic */
      #mobile-menu {
        display: none; /* Κλειστό από προεπιλογή */
      }
      #mobile-menu.show-menu {
        display: block !important;
        animation: fadeIn 0.2s ease-out;
      }
      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .mobile-link {
        display: block;
        padding: 1rem;
        color: white;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border-bottom: 1px solid rgba(255,255,255,0.05);
      }
    </style>
  </head>

  <body class="min-h-screen antialiased bg-black text-white">
    <header id="main-header">
      <div class="mx-auto max-w-7xl px-4">
        <div class="rounded-full border border-fuchsia-500/20 bg-black/90 backdrop-blur-md px-5 py-2.5 shadow-2xl">
          <div class="flex items-center justify-between">
            <a href="/" class="flex-shrink-0">
              <img src={logoPath} alt="Logo" class="h-[22px] w-auto sm:h-[30px]" />
            </a>

            <nav class="hidden lg:flex items-center gap-x-6">
              <a href="#player" class="text-[11px] font-bold uppercase tracking-wider text-fuchsia-400">Player</a>
              <a href="#beats" class="text-[11px] font-bold uppercase tracking-wider text-gray-300">Beats</a>
              <a href={spotifyLink} target="_blank" class="text-[11px] font-bold uppercase tracking-wider text-gray-300">Spotify</a>
            </nav>

            <div class="flex items-center gap-3">
               <a href={beatstarsLinks.profile} target="_blank" class="rounded-full bg-fuchsia-600 px-4 py-1.5 text-[10px] font-black uppercase text-white">Store</a>
               
               <button id="burger-btn" class="lg:hidden p-1 text-fuchsia-400" aria-label="Menu">
                 <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                   <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16m-7 6h7"/>
                 </svg>
               </button>
            </div>
          </div>
        </div>

        <div id="mobile-menu" class="mt-3">
          <div class="rounded-3xl border border-fuchsia-500/20 bg-black/95 backdrop-blur-xl p-4 shadow-2xl overflow-hidden">
            <a href="#player" class="mobile-link text-fuchsia-400">Player</a>
            <a href="#beats" class="mobile-link">Beats</a>
            <a href="#drumkits" class="mobile-link">Drum Kits</a>
            <a href={spotifyLink} target="_blank" class="mobile-link">Spotify</a>
            <a href={discordInvite} target="_blank" class="mobile-link">Discord</a>
          </div>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-4">
      <slot />
    </main>

    <script is:inline>
      // Χρησιμοποιούμε DOMContentLoaded για να είμαστε σίγουροι ότι το script τρέχει αφού φορτώσουν όλα
      document.addEventListener('DOMContentLoaded', () => {
        const btn = document.getElementById('burger-btn');
        const menu = document.getElementById('mobile-menu');

        if (btn && menu) {
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            menu.classList.toggle('show-menu');
            console.log('Menu toggled'); // Για debug στον browser του κινητού
          });

          // Κλείσιμο όταν πατάς ένα link
          const links = menu.querySelectorAll('a');
          links.forEach(link => {
            link.addEventListener('click', () => {
              menu.classList.remove('show-menu');
            });
          });

          // Κλείσιμο αν πατήσεις έξω
          document.addEventListener('click', (e) => {
            if (!menu.contains(e.target) && !btn.contains(e.target)) {
              menu.classList.remove('show-menu');
            }
          });
        }
      });
    </script>
  </body>
</html>