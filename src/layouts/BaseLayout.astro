---
import "../styles/global.css";
import en from "../i18n/en";
import el from "../i18n/el";
import { beatstarsLinks, socialLinks } from "../config/links";

interface Props {
  title?: string;
}

const { title = "Mr. Bonzo | Type Beats" } = Astro.props;
const logoPath = "/images/logo-main.webp";
const i18nPayload = { en, el };

const discordInvite = socialLinks.discord || "https://discord.gg/hmpCHd4J"; 
const ytArtist = "https://www.youtube.com/@mrbonzomusic";
const ytBeats = "https://www.youtube.com/@mrbonzobeatz";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    
    <style is:global>
      /* ΕΠΙΒΟΛΗ Z-INDEX ΚΑΙ ΧΡΩΜΑΤΩΝ */
      header#super-header {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        width: 100% !important;
        z-index: 9999999 !important; /* Maximum Priority */
        background-color: rgba(0, 0, 0, 0.9) !important;
        backdrop-filter: blur(20px) !important;
        -webkit-backdrop-filter: blur(20px) !important;
        border-bottom: 1px solid rgba(217, 70, 239, 0.4) !important;
        height: 80px !important;
        display: flex !important;
        align-items: center !important;
      }

      /* ΤΑ ΕΓΧΡΩΜΑ MENU ΠΟΥ ΗΘΕΛΕΣ */
      .nav-link-color {
        color: #d946ef !important; /* Φούξια */
        font-weight: 900 !important;
        text-transform: uppercase !important;
        letter-spacing: 0.1em !important;
        font-size: 10px !important;
        transition: all 0.3s ease !important;
      }

      .nav-link-color:hover {
        color: #ffffff !important;
        text-shadow: 0 0 10px #d946ef !important;
      }

      body {
        padding-top: 80px !important;
        margin: 0 !important;
        background-color: black !important;
      }

      /* Αποτροπή επικάλυψης από Player */
      iframe, #player, .beatstars-player {
        z-index: 1 !important;
        position: relative !important;
      }
    </style>
  </head>

  <body>
    <header id="super-header">
      <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="rounded-full border border-fuchsia-500/30 bg-black/40 px-6 py-2 shadow-[0_0_20px_rgba(192,38,211,0.3)]">
          <div class="flex items-center justify-between">
            
            <a href="/" class="flex-shrink-0">
              <img src={logoPath} alt="Logo" class="h-[25px] sm:h-[30px]" />
            </a>

            <nav class="hidden lg:flex items-center gap-x-6">
              <a href="#beats" class="nav-link-color">Beats</a>
              <a href="#drumkits" class="nav-link-color">Kits</a>
              <a href="#player" class="nav-link-color">Player</a>
              
              <div class="relative group cursor-pointer">
                <button type="button" class="nav-link-color flex items-center gap-1 outline-none">
                  YouTube <svg class="h-2 w-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4"><path d="M19 9l-7 7-7-7"/></svg>
                </button>
                <div class="invisible group-hover:visible opacity-0 group-hover:opacity-100 absolute top-full left-0 mt-3 w-44 rounded-xl border border-fuchsia-500/20 bg-black p-1 shadow-2xl transition-all">
                  <a href={ytArtist} target="_blank" class="block rounded-lg px-4 py-2 text-[10px] font-bold text-fuchsia-400 hover:text-white transition">Artist Channel</a>
                  <a href={ytBeats} target="_blank" class="block rounded-lg px-4 py-2 text-[10px] font-bold text-fuchsia-400 hover:text-white border-t border-white/5 transition">Beats Channel</a>
                </div>
              </div>

              <a href="#about" class="nav-link-color">About</a>
              <a href="#contact" class="nav-link-color">Contact</a>
            </nav>

            <div class="flex items-center gap-4">
               <div class="flex items-center font-bold text-[8px] border-r border-fuchsia-500/20 pr-3">
                  <button type="button" data-lang-switch="en" class="text-fuchsia-200/40 data-[active=true]:text-fuchsia-500 px-1 hover:text-white transition">EN</button>
                  <button type="button" data-lang-switch="el" class="text-fuchsia-200/40 data-[active=true]:text-fuchsia-500 px-1 hover:text-white transition">EL</button>
               </div>
               
               <a href={beatstarsLinks.profile} target="_blank" class="rounded-full bg-fuchsia-600 px-5 py-1.5 text-[9px] font-black uppercase text-white hover:bg-fuchsia-500 transition">Store</a>

               <button id="burger-btn" class="lg:hidden text-fuchsia-500">
                 <svg id="burger-open" class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"/></svg>
               </button>
            </div>
          </div>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 pb-12 sm:px-6 lg:px-8">
      <slot />
    </main>

    <script is:inline define:vars={{ i18nPayload }}>
      // Lang & Burger Logic
      const burgerBtn = document.getElementById('burger-btn');
      // ... (το script σου για το menu)
    </script>
  </body>
</html>
