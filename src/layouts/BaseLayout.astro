---
import "../styles/global.css";
import en from "../i18n/en";
import el from "../i18n/el";
import { beatstarsLinks, socialLinks } from "../config/links";

interface Props {
  title?: string;
}

const { title = "Mr. Bonzo | Type Beats" } = Astro.props;
const logoPath = "/images/logo-main.webp";
const i18nPayload = { en, el };

const discordInvite = socialLinks.discord || "https://discord.gg/hmpCHd4J"; 
const pond5Link = "https://www.pond5.com/artist/mrbonzobeats";
const ytArtist = "https://www.youtube.com/@mrbonzomusic";
const ytBeats = "https://www.youtube.com/@mrbonzobeatz";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    
    <style is:global>
      /* ΑΥΤΟ ΕΙΝΑΙ ΤΟ ΚΛΕΙΔΙ */
      :root {
        --header-height: 70px;
      }
      
      header#super-header {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        width: 100% !important;
        height: var(--header-height) !important;
        z-index: 2147483647 !important; /* Το μέγιστο δυνατό z-index στο web */
        background-color: rgba(0, 0, 0, 0.95) !important;
        backdrop-filter: blur(20px) !important;
        -webkit-backdrop-filter: blur(20px) !important;
        display: flex !important;
        align-items: center !important;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1) !important;
      }

      body {
        padding-top: var(--header-height) !important; /* Σπρώχνει όλο το site κάτω αυτόματα */
        margin: 0 !important;
      }

      /* Διόρθωση για τα iframes του Beatstars που μπαίνουν μπροστά */
      iframe, .beatstars-player, #player {
        z-index: 1 !important;
        position: relative !important;
      }
    </style>
  </head>

  <body class="bg-black text-white antialiased">
    
    <header id="super-header">
      <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between">
          
          <a href="/" class="flex-shrink-0 transition hover:scale-110">
            <img src={logoPath} alt="Logo" class="h-[25px] w-auto sm:h-[35px]" />
          </a>

          <nav class="hidden lg:flex items-center gap-x-6">
            <a href="#beats" class="text-[10px] font-bold uppercase tracking-widest text-gray-300 hover:text-fuchsia-400 transition">Beats</a>
            <a href="#drumkits" class="text-[10px] font-bold uppercase tracking-widest text-gray-300 hover:text-fuchsia-400 transition">Kits</a>
            <a href="#player" class="text-[10px] font-bold uppercase tracking-widest text-gray-300 hover:text-fuchsia-400 transition">Player</a>
            <a href={socialLinks.spotify} target="_blank" class="text-[10px] font-bold uppercase tracking-widest text-gray-300 hover:text-fuchsia-400 transition">Spotify</a>
            <a href="#about" class="text-[10px] font-bold uppercase tracking-widest text-gray-300 hover:text-fuchsia-400 transition">About</a>
            <a href="#contact" class="text-[10px] font-bold uppercase tracking-widest text-gray-300 hover:text-fuchsia-400 transition">Contact</a>
          </nav>

          <div class="flex items-center gap-3">
             <div class="flex items-center font-bold text-[9px] border-r border-white/10 pr-3">
                <button type="button" data-lang-switch="en" class="text-gray-500 data-[active=true]:text-fuchsia-400 px-1">EN</button>
                <button type="button" data-lang-switch="el" class="text-gray-500 data-[active=true]:text-fuchsia-400 px-1">EL</button>
             </div>
             
             <a href={beatstarsLinks.profile} target="_blank" class="hidden sm:block rounded-full bg-fuchsia-600 px-5 py-2 text-[10px] font-black uppercase text-white shadow-lg">Store</a>

             <button id="burger-btn" class="lg:hidden p-2 text-fuchsia-400 bg-white/5 rounded-lg">
               <svg id="burger-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"/></svg>
               <svg id="burger-close" class="hidden w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
             </button>
          </div>
        </div>
      </div>

      <div id="mobile-menu" class="hidden fixed inset-0 top-[70px] bg-black z- backdrop-blur-3xl">
        <div class="flex flex-col gap-6 p-8">
          <a href="#beats" class="mobile-link text-xl font-black uppercase text-white">Beats</a>
          <a href="#drumkits" class="mobile-link text-xl font-black uppercase text-white">Drum Kits</a>
          <a href="#player" class="mobile-link text-xl font-black uppercase text-white">Player</a>
          <a href="#about" class="mobile-link text-xl font-black uppercase text-white">About</a>
          <a href="#contact" class="mobile-link text-xl font-black uppercase text-fuchsia-400">Contact</a>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 pb-12 sm:px-6 lg:px-8">
      <slot />
    </main>

    <script is:inline define:vars={{ i18nPayload }}>
      // Logic για γλώσσες και burger
      const dictionaries = i18nPayload;
      const applyLanguage = (lang) => {
        const dict = dictionaries[lang] || dictionaries.en;
        localStorage.setItem("site-lang", lang);
        document.querySelectorAll("[data-lang-switch]").forEach((btn) => {
          btn.setAttribute("data-active", btn.getAttribute("data-lang-switch") === lang ? "true" : "false");
        });
        // Εδώ προσθέτεις το translation logic αν το χρειάζεσαι ενεργό
      };
      applyLanguage(localStorage.getItem("site-lang") || "en");

      const burgerBtn = document.getElementById('burger-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      burgerBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
        document.body.style.overflow = mobileMenu.classList.contains('hidden') ? 'auto' : 'hidden';
      });
    </script>
  </body>
</html>