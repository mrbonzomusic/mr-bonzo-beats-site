---
import { beatstarsLinks } from "../config/links";

// Χρησιμοποιούμε το σωστό format URL για να αποφύγουμε το 403 Forbidden
const playerUrl = "https://www.beatstars.com/player/?storeId=133234";
---

<section id="player" class="scroll-mt-24 px-4 sm:px-6">
  <div class="relative mx-auto max-w-7xl group">
    <div class="absolute -inset-1 bg-gradient-to-r from-fuchsia-600/20 to-purple-600/20 rounded-[2.5rem] blur opacity-75 group-hover:opacity-100 transition duration-1000"></div>
    
    <div class="relative overflow-hidden rounded-[2.5rem] border border-white/10 bg-black p-1 shadow-2xl">
      <iframe
        src={playerUrl}
        width="100%"
        title="Mr. Bonzo Beatstars Player"
        style="height: calc(100dvh - 160px); min-height: 500px; border:none; border-radius: 32px;"
        loading="lazy"
        class="bg-black w-full"
        allow="autoplay"
      >
        -- Your browser does not support iframes --
      </iframe>
    </div>
  </div>

  <p class="mt-4 text-center text-[10px] tracking-[0.2em] text-white/20 uppercase font-medium">
    Secure Checkout • Licensing & Contracts powered by Beatstars
  </p>
</section>