---
const artists = ["Thanasimos", "Saske", "ΔΠΘ", "Xplicit", "Efta", "RAF", "Pala Tranx", "Slogan"];
---

<section id="collaborations" class="relative mt-16 overflow-hidden rounded-3xl border border-fuchsia-500/30 bg-black/80 px-6 py-8 sm:px-10">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_0%_50%,rgba(168,85,247,0.14),transparent_35%),radial-gradient(circle_at_100%_50%,rgba(217,70,239,0.12),transparent_35%)]"></div>
  <div class="relative">
    <h3 class="text-2xl font-black uppercase tracking-tight text-white sm:text-3xl">Collaborations</h3>
    <p class="mt-2 text-sm text-purple-100/75">Artists and projects developed through Purple Sound Studio.</p>
    <div class="mt-5 flex flex-wrap gap-2">
      {
        artists.map((artist) => (
          <span class="rounded-full border border-fuchsia-500/40 bg-black/70 px-4 py-2 text-xs font-bold uppercase tracking-[0.16em] text-fuchsia-200">
            {artist}
          </span>
        ))
      }
    </div>
  </div>
</section>
