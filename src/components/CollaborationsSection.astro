---
import { collaborators } from "../config/collaborations";

const safeCollaborators = collaborators || [];
const marquee = [...safeCollaborators, ...safeCollaborators];
---

<section id="collaborations" class="relative mt-8 overflow-hidden bg-black/40 py-4 sm:py-6">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(217,70,239,0.05),transparent_70%)]"></div>
  
  <div class="relative flex flex-col items-center gap-4 sm:flex-row sm:px-10">
    <h3 class="flex-shrink-0 text-[10px] font-black uppercase tracking-[0.3em] text-fuchsia-500/80 sm:border-r sm:border-fuchsia-500/20 sm:pr-8" data-i18n="collaborations.title">
      Collaborations
    </h3>
    
    <div class="marquee-track w-full">
      <div class="marquee-content">
        {
          marquee.length > 0 ? (
            marquee.map((artist, idx) => (
              <span class="inline-flex items-center text-[11px] font-bold uppercase tracking-[0.2em] text-fuchsia-100/60 sm:text-xs">
                {artist}
                <span class="mx-6 text-fuchsia-500/30">✦</span>
              </span>
            ))
          ) : (
            <span class="text-[10px] uppercase tracking-widest text-fuchsia-200/30" data-i18n="collaborations.comingSoon">Updating...</span>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .marquee-track {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .marquee-content {
    display: inline-flex;
    white-space: nowrap;
    animation: brand-ticker 30s linear infinite; /* Πιο γρήγορο για μικρότερο ύψος */
  }

  @keyframes brand-ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .marquee-track:hover .marquee-content {
    animation-play-state: paused;
  }
</style>