---
import { socialLinks } from "../config/links";
---

<footer class="mt-24 border-t border-white/10 py-12 px-4">
  <div class="max-w-7xl mx-auto flex flex-col gap-8 text-center lg:flex-row lg:items-center lg:justify-between lg:text-left">
    
    <div class="order-2 lg:order-1">
      <p class="text-[11px] uppercase tracking-[0.25em] text-gray-500 font-medium">
        &copy; {new Date().getFullYear()} <span class="text-fuchsia-500/80 font-bold">Mr. Bonzo</span>. 
        <span class="block sm:inline sm:ml-2 opacity-60" data-i18n="footer.rights">All rights reserved.</span>
      </p>
    </div>

    <div class="order-3 lg:order-2 flex flex-col items-center gap-1.5 opacity-50 hover:opacity-100 transition-opacity duration-500">
      <span class="text-[9px] font-black uppercase tracking-[0.3em] text-fuchsia-400/70">Traffic</span>
      <img 
        src="https://hits.seeyoufarm.com/api/count/incr/badge.svg?url=https%3A%2F%2Fmrbonzo-beats.pages.dev&count_bg=%23d946ef&title_bg=%231a1a1a&icon=&icon_color=%23E7E7E7&title=Visits&edge_flat=true" 
        alt="Visitor Counter"
        class="h-4 w-auto grayscale contrast-125"
      />
    </div>

    <div class="order-1 lg:order-3 flex flex-wrap items-center justify-center gap-x-6 gap-y-4 lg:justify-end">
      {[
        { name: "Instagram", href: socialLinks.instagram },
        { name: "YouTube", href: socialLinks.youtube },
        { name: "Email", href: socialLinks.email },
        { name: "TikTok", href: socialLinks.tiktok },
        { name: "Spotify", href: socialLinks.spotify }
      ].map((link) => (
        <a
          href={link.href}
          target={link.name !== "Email" ? "_blank" : undefined}
          rel={link.name !== "Email" ? "noopener noreferrer" : undefined}
          class="text-[11px] font-black uppercase tracking-[0.2em] text-gray-400 transition-all duration-300 hover:text-fuchsia-400 hover:translate-y-[-2px]"
        >
          {link.name}
        </a>
      ))}
    </div>
    
  </div>
</footer>