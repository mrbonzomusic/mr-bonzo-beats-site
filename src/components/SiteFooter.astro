<script is:inline>
  async function loadGoatStats() {
    const el = document.getElementById('stats-count');
    if (!el) return;
    
    try {
      // Το cache: 'no-store' λέει στον browser "μην διαβάζεις το παλιό, φέρε το φρέσκο"
      const res = await fetch(`https://mrbonzo.goatcounter.com/counter//total.json?t=${Date.now()}`, {
        cache: 'no-store'
      });
      const data = await res.json();
      
      if (data && data.count) {
        const cleanCount = data.count.replace(/\s/g, '').replace(/,/g, '');
        el.innerText = cleanCount.padStart(4, '0');
        console.log("Counter updated to:", cleanCount);
      }
    } catch (e) {
      console.error("Counter error:", e);
    }
  }

  // Refresh κάθε 10 δευτερόλεπτα
  loadGoatStats();
  setInterval(loadGoatStats, 10000);
</script>