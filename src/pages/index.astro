---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import CollaborationsSection from "../components/CollaborationsSection.astro";
import TypeBeatGrid from "../components/TypeBeatGrid.astro";
import FeaturedBeatstars from "../components/FeaturedBeatstars.astro";
import DrumKits from "../components/DrumKits.astro";
import DiscographySection from "../components/DiscographySection.astro";
import AboutSection from "../components/AboutSection.astro";
import ServicesSection from "../components/ServicesSection.astro";
import ContactSection from "../components/ContactSection.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { getArtistAlbums, extractSpotifyArtistId, getReleasesFromRss, getReleasesFromSpotifyPage } from "../lib/spotify";
import { socialLinks } from "../config/links";

// ΕΙΣΑΓΩΓΗ ΓΛΩΣΣΩΝ
import en from "../i18n/en";
import el from "../i18n/el";

const fallbackCover = "/images/logo-main.webp";
const scrapedData = await getReleasesFromSpotifyPage({
  artistUrl: socialLinks.spotify,
  fallbackCover,
});

let spotifyData = scrapedData;

if (!(spotifyData.status === "scrape" && spotifyData.releases.length > 0)) {
  const rssData = await getReleasesFromRss({
    feedUrl: import.meta.env.RELEASES_RSS_URL,
    fallbackCover,
  });

  spotifyData =
    rssData.status === "rss" && rssData.releases.length > 0
      ? rssData
      : await getArtistAlbums({
          clientId: import.meta.env.SPOTIFY_CLIENT_ID,
          clientSecret: import.meta.env.SPOTIFY_CLIENT_SECRET,
          artistId: import.meta.env.SPOTIFY_ARTIST_ID || extractSpotifyArtistId(socialLinks.spotify),
          fallbackCover,
        });
}
---

<BaseLayout title="Mr. Bonzo | Beatmaker Portfolio">
  
  <Hero />

  <CollaborationsSection />

  <section id="player" class="scroll-mt-24">
    <FeaturedBeatstars />
  </section>

  <section id="beats" class="scroll-mt-24">
    <TypeBeatGrid />
  </section>

  <section id="drumkits" class="scroll-mt-24">
    <DrumKits />
  </section>

  <section id="latest-releases" class="scroll-mt-24">
    <DiscographySection releases={spotifyData.releases} status={spotifyData.status} />
  </section>

  <section id="about" class="scroll-mt-24">
    <AboutSection />
    <ServicesSection />
  </section>
  
  <section id="contact" class="scroll-mt-24">
    <ContactSection /> 
  </section>

  <SiteFooter />

</BaseLayout>

<script is:inline>
  /**
   * CLIENT-SIDE TRANSLATION LOGIC
   * Αυτό το script τρέχει στον browser. Αν ο χρήστης έχει επιλέξει 'el',
   * μπορούμε να κάνουμε manipulate το DOM εδώ, ή να αφήσουμε τα 
   * React/Island components να το κάνουν.
   */
  document.addEventListener('DOMContentLoaded', () => {
    const savedLang = localStorage.getItem('selected-lang') || 'en';
    if (savedLang === 'el') {
      // Εδώ κανονικά θα έπρεπε να αλλάξουμε τα κείμενα χειροκίνητα αν τα components 
      // δεν είναι "reactive". 
      console.log("Language detected: Greek. Updating UI...");
    }
  });
</script>